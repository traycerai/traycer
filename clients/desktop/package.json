{
  "name": "@traycer-clients/desktop",
  "productName": "Traycer",
  "version": "0.0.0",
  "description": "Traycer standalone desktop shell (Electron) hosting the gui-app renderer; host lifecycle is delegated to the Traycer CLI.",
  "homepage": "https://traycer.ai",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "clean:main": "rimraf dist/main dist/packages dist/protocol dist/clients",
    "compile": "tsc --noEmit -p tsconfig.json",
    "build:main": "bun run clean:main && bun scripts/build-main-bundle.cjs",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:app": "bun run clean && bun run build:main && bun run build:renderer",
    "prepack:check-cli": "bun scripts/prepack/check-cli-resource.cjs",
    "prepack:check-icons": "bun scripts/prepack/check-bundle-icons.cjs",
    "prepack:check-tray": "bun scripts/prepack/check-tray-assets.cjs",
    "build": "bun run build:app",
    "package": "bun run build:app && bun run prepack:check-cli && bun run prepack:check-icons && bun run prepack:check-tray && bun x electron-builder --publish never",
    "package:dir": "bun run build:app && bun run prepack:check-cli && bun run prepack:check-icons && bun run prepack:check-tray && bun x electron-builder --dir --publish never",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "dev:main": "bun run build:main && bun scripts/dev/dev-main.cjs",
    "dev": "bun x concurrently -k -n renderer,main -c blue,magenta \"bun run dev:renderer\" \"bun x wait-on tcp:5173 && bun run dev:main\"",
    "lint": "eslint . --cache --fix --max-warnings 0",
    "format": "bun x prettier --write .",
    "test": "vitest run",
    "test:resolution": "VITE_DESKTOP_LOCAL_STORAGE_KEY=traycer-resolution-test-local-storage-key bun run build:app && bun scripts/resolution/run-resolution-matrix.cjs"
  },
  "dependencies": {
    "@sentry/browser": "10.62.0",
    "@sentry/electron": "^7.15.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "encrypt-storage": "^2.14.7",
    "font-list": "^2.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@sentry/esbuild-plugin": "^5.3.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "ai.traycer.desktop",
    "productName": "Traycer",
    "artifactName": "traycer-desktop-${arch}.${ext}",
    "asar": true,
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false
    },
    "directories": {
      "buildResources": "resources/bundle",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!**/*.map",
      "node_modules/font-list/**/*"
    ],
    "asarUnpack": [
      "node_modules/font-list/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/app",
        "to": "app",
        "filter": [
          "**/*.png"
        ]
      },
      {
        "from": "dist/renderer",
        "to": "renderer",
        "filter": [
          "**/*",
          "!**/*.map"
        ]
      },
      {
        "from": "resources/host",
        "to": "host",
        "filter": [
          "README.md",
          ".gitkeep"
        ]
      },
      {
        "from": "resources/cli",
        "to": "cli",
        "filter": [
          "**/*",
          "!README.md"
        ]
      },
      {
        "from": "resources/tray",
        "to": "tray",
        "filter": [
          "**/*.png"
        ]
      }
    ],
    "protocols": [
      {
        "name": "Traycer",
        "schemes": [
          "traycer"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "traycerai",
        "repo": "traycer"
      }
    ],
    "mac": {
      "artifactName": "traycer-desktop-macos-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "minimumSystemVersion": "12.0",
      "entitlements": "resources/bundle/entitlements.mac.plist",
      "entitlementsInherit": "resources/bundle/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Traycer uses the microphone for voice dictation in the composer."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "artifactName": "traycer-desktop-windows-${arch}.${ext}",
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "artifactName": "traycer-desktop-linux-${arch}.${ext}",
      "executableName": "traycer-desktop",
      "maintainer": "Traycer AI <support@traycer.ai>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "author": {
    "name": "Traycer AI",
    "email": "support@traycer.ai"
  },
  "license": "Apache-2.0"
}
